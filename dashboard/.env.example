# Copy to .env.local

# --- Supabase (auth + Postgres) ---
# Project Settings → API. Leave all three empty to run in local dev mode
# (no sign-in, in-memory data, LMSPEND_DEV_KEYS auth).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dev-mode API keys for CLI sync, comma-separated "key:email" pairs.
# Ignored once Supabase is configured (real keys live in the api_keys table).
LMSPEND_DEV_KEYS=dev-key-123:you@example.com

# Optional second lock on /admin: passcode after an is_admin user signs in.
# Admins are stored in Postgres (users.is_admin). Leave empty to disable.
# Failed unlocks lock out for 15 minutes after 5 attempts.
LMSPEND_ADMIN_PASSCODE=

# --- Kora / Korapay (card payments; supports individual businesses in Nigeria) ---
# Dashboard → Settings → API Keys. Use test keys until launch.
KORA_SECRET_KEY=
# USD if enabled on your Kora account; otherwise set NGN and adjust amounts.
KORA_CURRENCY=USD
# Flip to true only when real Kora keys are ready to collect payment.
# Until then the app stays on free-tier beta (upgrade CTAs disabled).
PAYMENTS_ENABLED=false

# --- Resend (emails: budget alerts, monthly reports, renewal reminders) ---
# Leave empty in dev — emails are logged to the console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=LMSpend <reports@yourdomain.com>

# --- Cron protection (any random string; send as "Authorization: Bearer <it>") ---
CRON_SECRET=

# Base URL of this app (checkout redirects, auth callback, emails, share links, SEO canonicals)
# Must be the real public HTTPS host — typos break X/IG/WhatsApp link previews.
# Production: https://lmspend.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional X/Twitter handle for card attribution (e.g. @lmspend)
NEXT_PUBLIC_TWITTER_HANDLE=
