  },
  "keywords": [
    "ai",
    "claude-code",
    "cursor",
    "codex",
    "cost",
    "usage",
    "cli"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
