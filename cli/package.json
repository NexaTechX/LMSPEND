  "description": "See what you actually spend on AI coding tools — Claude Code, Codex, Cursor — from the logs already on your machine. Local-first, zero deps.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lmspend": "./dist/index.js"
  },
  "files": [
    "dist",
    "pricing.json"
  ],
